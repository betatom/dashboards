<script>
/* ═══════════════════════════════════════════════
   CONFIG
   ═══════════════════════════════════════════════ */
const URLS = {
    master:   'https://docs.google.com/spreadsheets/d/e/2PACX-1vSnc7WO9gTwY92cd6a5k1xNz1KIv2yccT5xgmcMnc7InaBO0y4aFUejcYJ5D2c43AhaclWAWqMXqHt0/pub?gid=2129030269&single=true&output=csv',
    creative: 'https://docs.google.com/spreadsheets/d/e/2PACX-1vSnc7WO9gTwY92cd6a5k1xNz1KIv2yccT5xgmcMnc7InaBO0y4aFUejcYJ5D2c43AhaclWAWqMXqHt0/pub?gid=941993287&single=true&output=csv',
    audience: 'https://docs.google.com/spreadsheets/d/e/2PACX-1vSnc7WO9gTwY92cd6a5k1xNz1KIv2yccT5xgmcMnc7InaBO0y4aFUejcYJ5D2c43AhaclWAWqMXqHt0/pub?gid=792299986&single=true&output=csv',
};

const SAGE = '#93B19D';
const CHARCOAL = '#2D2D2D';
const COLORS = ['#93B19D', '#2D2D2D', '#D4A574', '#7A9DBF', '#C47E7E', '#8B7EC4'];

let charts = {};

/* ═══════════════════════════════════════════════
   CSV PARSING
   ═══════════════════════════════════════════════ */
function parseCSVLine(line) {
    const r = []; let cur = '', inQ = false;
    for (let i = 0; i < line.length; i++) {
        const c = line[i];
        if (inQ) {
            if (c === '"' && line[i+1] === '"') { cur += '"'; i++; }
            else if (c === '"') { inQ = false; }
            else { cur += c; }
        } else {
            if (c === '"') { inQ = true; }
            else if (c === ',') { r.push(cur); cur = ''; }
            else { cur += c; }
        }
    }
    r.push(cur);
    return r;
}

function parseCSV(text) {
    const lines = text.trim().split('\n').filter(l => l.trim());
    if (lines.length < 2) return { headers: [], rows: [] };
    const headers = parseCSVLine(lines[0]).map(h => h.trim());
    const rows = [];
    for (let i = 1; i < lines.length; i++) {
        const vals = parseCSVLine(lines[i]);
        const row = {};
        headers.forEach((h, idx) => { row[h] = (vals[idx] || '').trim(); });
        rows.push(row);
    }
    return { headers, rows };
}

/* ═══════════════════════════════════════════════
   NUMBER UTILS
   ═══════════════════════════════════════════════ */
function toNum(val) {
    if (val === undefined || val === null || val === '') return 0;
    const cleaned = String(val).replace(/[£$€,%\s]/g, '').replace(/,/g, '');
    const n = parseFloat(cleaned);
    return isNaN(n) ? 0 : n;
}

function fmt(n, type) {
    switch(type) {
        case 'gbp':
            if (n >= 1000000) return '\u00A3' + (n/1e6).toFixed(1) + 'M';
            if (n >= 1000) return '\u00A3' + (n/1e3).toFixed(1) + 'K';
            return '\u00A3' + n.toFixed(2);
        case 'gbp-short':
            if (n >= 1000000) return '\u00A3' + (n/1e6).toFixed(1) + 'M';
            if (n >= 1000) return '\u00A3' + (n/1e3).toFixed(1) + 'K';
            return '\u00A3' + n.toFixed(0);
        case 'num':
            if (n >= 1000000) return (n/1e6).toFixed(1) + 'M';
            if (n >= 1000) return (n/1e3).toFixed(1) + 'K';
            return n.toLocaleString('en-GB', { maximumFractionDigits: 0 });
        case 'pct': return n.toFixed(2) + '%';
        case 'roas': return n.toFixed(2) + 'x';
        default: return String(n);
    }
}

/* ═══════════════════════════════════════════════
   DATE HELPERS
   ═══════════════════════════════════════════════ */
function getLastWeekRange() {
    const today = new Date();
    today.setHours(0,0,0,0);
    const day = today.getDay(); // 0=Sun, 1=Mon...
    // Find most recent Monday
    const thisMon = new Date(today);
    thisMon.setDate(today.getDate() - ((day + 6) % 7));
    // Last week is the Mon-Sun before this Monday
    const lastSun = new Date(thisMon);
    lastSun.setDate(thisMon.getDate() - 1);
    const lastMon = new Date(lastSun);
    lastMon.setDate(lastSun.getDate() - 6);

    return {
        start: toLocalISO(lastMon),
        end: toLocalISO(lastSun),
        label: formatDateShort(lastMon) + ' \u2013 ' + formatDateShort(lastSun),
    };
}

function toLocalISO(d) {
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return y + '-' + m + '-' + day;
}

function formatDateShort(d) {
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
}

function isInRange(dateStr, start, end) {
    return dateStr >= start && dateStr <= end;
}

/* ═══════════════════════════════════════════════
   AGGREGATION
   ═══════════════════════════════════════════════ */
function aggregateMaster(rows, dateFilter) {
    const filtered = dateFilter
        ? rows.filter(r => isInRange(r['Date'], dateFilter.start, dateFilter.end))
        : rows;
    const s = { spend:0, reach:0, clicks:0, impressions:0, purchases:0, convValue:0 };
    filtered.forEach(r => {
        s.spend += toNum(r['Amount spent']);
        s.reach += toNum(r['Reach']);
        s.clicks += toNum(r['Link Clicks']);
        s.impressions += toNum(r['Impressions']);
        s.purchases += toNum(r['Purchases']);
        s.convValue += toNum(r['Purchases conversion value']);
    });
    s.ctr = s.impressions > 0 ? (s.clicks / s.impressions) * 100 : 0;
    s.cpc = s.clicks > 0 ? s.spend / s.clicks : 0;
    s.cvr = s.clicks > 0 ? (s.purchases / s.clicks) * 100 : 0;
    s.roas = s.spend > 0 ? s.convValue / s.spend : 0;
    s.apv = s.purchases > 0 ? s.convValue / s.purchases : 0;
    s.cpp = s.purchases > 0 ? s.spend / s.purchases : 0;
    return s;
}

function aggregateByName(rows, nameCol, dateCol, dateFilter) {
    const filtered = dateFilter
        ? rows.filter(r => isInRange(r[dateCol], dateFilter.start, dateFilter.end))
        : rows;
    const map = {};
    filtered.forEach(r => {
        const name = r[nameCol] || 'Unknown';
        if (!map[name]) map[name] = { name, spend:0, impressions:0, clicks:0, purchases:0, convValue:0 };
        const m = map[name];
        m.spend += toNum(r['Amount spent']);
        m.impressions += toNum(r['Impressions']);
        m.clicks += toNum(r['Link clicks'] || r['Link Clicks']);
        m.purchases += toNum(r['Purchases']);
        m.convValue += toNum(r['Purchases conversion value']);
    });
    return Object.values(map).map(m => {
        m.cpc = m.clicks > 0 ? m.spend / m.clicks : 0;
        m.ctr = m.impressions > 0 ? (m.clicks / m.impressions) * 100 : 0;
        m.cvr = m.clicks > 0 ? (m.purchases / m.clicks) * 100 : 0;
        m.roas = m.spend > 0 ? m.convValue / m.spend : 0;
        m.apv = m.purchases > 0 ? m.convValue / m.purchases : 0;
        m.cpp = m.purchases > 0 ? m.spend / m.purchases : 0;
        return m;
    }).sort((a, b) => b.spend - a.spend);
}

/* ═══════════════════════════════════════════════
   FETCH WITH CORS FALLBACK
   ═══════════════════════════════════════════════ */
async function fetchCSV(url) {
    const cb = '&_cb=' + Date.now();
    try {
        const r = await fetch(url + cb, {mode:'cors'});
        if (r.ok) { const t = await r.text(); if (t.includes(',')) return t; }
    } catch(e) {}
    try {
        const r = await fetch('https://api.allorigins.win/raw?url=' + encodeURIComponent(url + cb));
        if (r.ok) { const t = await r.text(); if (t.includes(',')) return t; }
    } catch(e) {}
    try {
        const r = await fetch('https://corsproxy.io/?' + encodeURIComponent(url + cb));
        if (r.ok) { const t = await r.text(); if (t.includes(',')) return t; }
    } catch(e) {}
    throw new Error('Could not fetch data. Ensure sheets are published and try serving via localhost:8000.');
}

/* ═══════════════════════════════════════════════
   RENDER: KPI ROW
   ═══════════════════════════════════════════════ */
function kpiHTML(m) {
    return `
    <div class="kpi-row">
        <div class="kpi-card">
            <div class="kpi-label">Spend</div>
            <div class="kpi-value">${fmt(m.spend,'gbp')}</div>
            <div class="kpi-sub">CPC: ${fmt(m.cpc,'gbp')}</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">ROAS</div>
            <div class="kpi-value">${fmt(m.roas,'roas')}</div>
            <div class="kpi-sub">Revenue: ${fmt(m.convValue,'gbp')}</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Purchases</div>
            <div class="kpi-value">${fmt(m.purchases,'num')}</div>
            <div class="kpi-sub">Cost/purchase: ${fmt(m.cpp,'gbp')}</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Link Clicks</div>
            <div class="kpi-value">${fmt(m.clicks,'num')}</div>
            <div class="kpi-sub">CTR: ${fmt(m.ctr,'pct')}</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">Reach</div>
            <div class="kpi-value">${fmt(m.reach,'num')}</div>
            <div class="kpi-sub">Impressions: ${fmt(m.impressions,'num')}</div>
        </div>
    </div>`;
}

/* ═══════════════════════════════════════════════
   RENDER: BREAKDOWN TABLE
   ═══════════════════════════════════════════════ */
function breakdownTableHTML(items) {
    if (!items.length) return '<p style="color:var(--grey-mid);font-size:12px;padding:8px 0;">No data for this period.</p>';
    let html = `<table class="data-table"><thead><tr>
        <th>Name</th><th class="num-right">Spend</th><th class="num-right">Revenue</th>
        <th class="num-right">ROAS</th><th class="num-right">Purchases</th>
        <th class="num-right">CPC</th><th class="num-right">CTR</th>
        <th class="num-right">CVR</th><th class="num-right">Clicks</th>
        <th class="num-right">Impressions</th>
    </tr></thead><tbody>`;
    items.forEach(m => {
        html += `<tr>
            <td class="name-col" title="${m.name}">${m.name}</td>
            <td class="num-right">${fmt(m.spend,'gbp')}</td>
            <td class="num-right">${fmt(m.convValue,'gbp')}</td>
            <td class="num-right">${fmt(m.roas,'roas')}</td>
            <td class="num-right">${fmt(m.purchases,'num')}</td>
            <td class="num-right">${fmt(m.cpc,'gbp')}</td>
            <td class="num-right">${fmt(m.ctr,'pct')}</td>
            <td class="num-right">${fmt(m.cvr,'pct')}</td>
            <td class="num-right">${fmt(m.clicks,'num')}</td>
            <td class="num-right">${fmt(m.impressions,'num')}</td>
        </tr>`;
    });
    // Totals
    const t = items.reduce((a, m) => {
        a.spend+=m.spend; a.convValue+=m.convValue; a.purchases+=m.purchases;
        a.clicks+=m.clicks; a.impressions+=m.impressions; return a;
    }, {spend:0,convValue:0,purchases:0,clicks:0,impressions:0});
    t.roas = t.spend>0 ? t.convValue/t.spend : 0;
    t.cpc = t.clicks>0 ? t.spend/t.clicks : 0;
    t.ctr = t.impressions>0 ? (t.clicks/t.impressions)*100 : 0;
    t.cvr = t.clicks>0 ? (t.purchases/t.clicks)*100 : 0;
    html += `<tr class="row-highlight">
        <td><strong>Total</strong></td>
        <td class="num-right"><strong>${fmt(t.spend,'gbp')}</strong></td>
        <td class="num-right"><strong>${fmt(t.convValue,'gbp')}</strong></td>
        <td class="num-right"><strong>${fmt(t.roas,'roas')}</strong></td>
        <td class="num-right"><strong>${fmt(t.purchases,'num')}</strong></td>
        <td class="num-right"><strong>${fmt(t.cpc,'gbp')}</strong></td>
        <td class="num-right"><strong>${fmt(t.ctr,'pct')}</strong></td>
        <td class="num-right"><strong>${fmt(t.cvr,'pct')}</strong></td>
        <td class="num-right"><strong>${fmt(t.clicks,'num')}</strong></td>
        <td class="num-right"><strong>${fmt(t.impressions,'num')}</strong></td>
    </tr></tbody></table>`;
    return html;
}

/* ═══════════════════════════════════════════════
   RENDER: CHARTS
   ═══════════════════════════════════════════════ */
function destroyCharts() { Object.values(charts).forEach(c => c.destroy()); charts = {}; }

function renderDailyChart(canvasId, masterRows, dateFilter) {
    const filtered = dateFilter
        ? masterRows.filter(r => isInRange(r['Date'], dateFilter.start, dateFilter.end))
        : masterRows.filter(r => toNum(r['Amount spent']) > 0);
    filtered.sort((a, b) => a['Date'].localeCompare(b['Date']));
    const labels = filtered.map(r => {
        const d = new Date(r['Date'] + 'T00:00:00');
        return d.toLocaleDateString('en-GB', { day:'numeric', month:'short' });
    });
    const ctx = document.getElementById(canvasId);
    if (!ctx) return;
    charts[canvasId] = new Chart(ctx, {
        type: 'bar',
        data: {
            labels,
            datasets: [
                { label:'Spend', data: filtered.map(r => toNum(r['Amount spent'])), backgroundColor: SAGE+'CC', borderColor: SAGE, borderWidth:1, borderRadius:4, order:2 },
                { label:'Revenue', data: filtered.map(r => toNum(r['Purchases conversion value'])), backgroundColor: CHARCOAL+'CC', borderColor: CHARCOAL, borderWidth:1, borderRadius:4, order:1 },
            ]
        },
        options: {
            responsive:true, maintainAspectRatio:false,
            plugins: { legend: { position:'top', labels: { usePointStyle:true, padding:12, font:{size:10,family:'Inter'} } },
                tooltip: { callbacks: { label: ctx => ctx.dataset.label + ': ' + fmt(ctx.parsed.y,'gbp') } }
            },
            scales: { x:{grid:{display:false}, ticks:{font:{size:10}}}, y:{beginAtZero:true, ticks:{callback:v=>fmt(v,'gbp-short'),font:{size:10}}, grid:{color:'#f0f0f0'}} }
        }
    });
}

function renderBreakdownChart(canvasId, items, metricKey, fmtType, label) {
    const ctx = document.getElementById(canvasId);
    if (!ctx || !items.length) return;
    charts[canvasId] = new Chart(ctx, {
        type: 'bar',
        data: {
            labels: items.map(m => m.name.length > 28 ? m.name.slice(0,25)+'...' : m.name),
            datasets: [{
                label, data: items.map(m => m[metricKey]),
                backgroundColor: items.map((_, i) => COLORS[i % COLORS.length] + 'CC'),
                borderColor: items.map((_, i) => COLORS[i % COLORS.length]),
                borderWidth:1, borderRadius:4,
            }]
        },
        options: {
            responsive:true, maintainAspectRatio:false,
            plugins: { legend:{display:false}, tooltip: { callbacks: { label: ctx => fmt(ctx.parsed.y, fmtType) } } },
            scales: {
                x: { grid:{display:false}, ticks:{font:{size:9}} },
                y: { beginAtZero:true, grid:{color:'#f0f0f0'}, ticks:{font:{size:10}} }
            }
        }
    });
}

/* ═══════════════════════════════════════════════
   MAIN RENDER
   ═══════════════════════════════════════════════ */
function renderDashboard(masterData, creativeData, audienceData) {
    const week = getLastWeekRange();
    const content = document.getElementById('dashboard-content');

    const masterAll = aggregateMaster(masterData.rows, null);
    const masterWeek = aggregateMaster(masterData.rows, week);
    const creativeAll = aggregateByName(creativeData.rows, 'Ad Name', 'Day', null);
    const creativeWeek = aggregateByName(creativeData.rows, 'Ad Name', 'Day', week);
    const audienceAll = aggregateByName(audienceData.rows, 'Adset Name', 'Day', null);
    const audienceWeek = aggregateByName(audienceData.rows, 'Adset Name', 'Day', week);

    content.innerHTML = `
        <!-- OVERALL: LAST WEEK -->
        <div class="section-label">Overall Performance \u2014 Last Week (${week.label})</div>
        ${kpiHTML(masterWeek)}

        <!-- OVERALL: ALL TIME -->
        <div class="section-label">Overall Performance \u2014 All Time</div>
        ${kpiHTML(masterAll)}

        <!-- DAILY TREND -->
        <div class="section-label">Daily Trend</div>
        <div class="charts-row">
            <div class="chart-card"><h3>Last Week \u2014 Spend vs Revenue</h3><canvas id="chart-daily-week" height="240"></canvas></div>
            <div class="chart-card"><h3>All Time \u2014 Spend vs Revenue</h3><canvas id="chart-daily-all" height="240"></canvas></div>
        </div>

        <!-- CREATIVE -->
        <div class="section-label">Creative Performance</div>
        <div class="table-card">
            <h3>Creative Breakdown \u2014 Last Week (${week.label})</h3>
            ${breakdownTableHTML(creativeWeek)}
        </div>
        <div class="table-card">
            <h3>Creative Breakdown \u2014 All Time</h3>
            ${breakdownTableHTML(creativeAll)}
        </div>

        <!-- AUDIENCE -->
        <div class="section-label">Audience (Ad Set) Performance</div>
        <div class="table-card">
            <h3>Ad Set Breakdown \u2014 Last Week (${week.label})</h3>
            ${breakdownTableHTML(audienceWeek)}
        </div>
        <div class="table-card">
            <h3>Ad Set Breakdown \u2014 All Time</h3>
            ${breakdownTableHTML(audienceAll)}
        </div>
    `;

    destroyCharts();
    renderDailyChart('chart-daily-week', masterData.rows, week);
    renderDailyChart('chart-daily-all', masterData.rows, null);
    // Creative and audience charts removed — tables only
}

/* ═══════════════════════════════════════════════
   LOAD ALL DATA
   ═══════════════════════════════════════════════ */
async function loadAllData() {
    const dot = document.getElementById('status-dot');
    const txt = document.getElementById('status-text');
    const upd = document.getElementById('last-updated');

    dot.className = 'status-dot loading';
    txt.textContent = 'Fetching 3 data sources...';

    try {
        const [masterCSV, creativeCSV, audienceCSV] = await Promise.all([
            fetchCSV(URLS.master),
            fetchCSV(URLS.creative),
            fetchCSV(URLS.audience),
        ]);

        const masterData = parseCSV(masterCSV);
        const creativeData = parseCSV(creativeCSV);
        const audienceData = parseCSV(audienceCSV);

        if (masterData.rows.length === 0) throw new Error('Master data returned no rows.');

        renderDashboard(masterData, creativeData, audienceData);

        const now = new Date();
        upd.textContent = 'Last refreshed: ' + now.toLocaleString('en-GB', { day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' });
        dot.className = 'status-dot';
        txt.textContent = 'Live \u2014 all 3 data sources loaded (' + masterData.rows.length + ' days, ' + creativeData.rows.length + ' creative rows, ' + audienceData.rows.length + ' audience rows)';

    } catch(err) {
        console.error('Load error:', err);
        dot.className = 'status-dot error';
        txt.textContent = 'Error loading data';
        document.getElementById('dashboard-content').innerHTML = `
            <div class="error-msg">
                <strong>Could not load data.</strong><br>${err.message}<br><br>
                <strong>To fix:</strong> serve this file from a local web server. Open Terminal, <code>cd</code> to the folder, then run:<br>
                <code style="background:#f5f5f5;padding:4px 8px;border-radius:4px;font-size:12px;">python3 -m http.server 8000</code><br>
                Then open <a href="http://localhost:8000/the-price-dashboard.html" style="color:#93B19D;">http://localhost:8000/the-price-dashboard.html</a>
            </div>`;
    }
}

loadAllData();
setInterval(loadAllData, 5 * 60 * 1000);
</script>
